# =============================================================================
# REQUIRED — both deployment modes
# =============================================================================

OPENAI_API_KEY=your-openai-api-key-here

# Security — set a strong random secret to protect all API endpoints.
# Without this, the app is fully public (no authentication required).
# Generate one: openssl rand -hex 32
# RAGAS_API_KEY=your-secret-here


# =============================================================================
# SERVER DEPLOYMENT (Northflank + Neon)
# =============================================================================
# PORT is set automatically by Northflank — no action needed.
# Set DATABASE_URL to your Neon connection string in Northflank env vars.
#
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# =============================================================================
# SELF-HOSTING (docker compose)
# =============================================================================
# Default port is 8000. Override by setting PORT= in your .env file.
# Leave DATABASE_URL unset to use local SQLite (stored in ./data/ragas.db).
#
# PORT=8000


# =============================================================================
# LLM PROVIDERS — optional, enables additional judge models
# =============================================================================

# LLM Gateway — routes ALL models through an OpenAI-compatible endpoint.
# When set, standard provider models (OpenAI/Anthropic/Gemini) are replaced
# by whichever models the gateway exposes.
# OPENAI_BASE_URL=https://your-llm-gateway-url/v1

# Gateway model discovery (only used when OPENAI_BASE_URL is set):
#   1. GATEWAY_MODELS_URL — custom endpoint if /models is at a non-standard path
#   2. Falls back to GET {OPENAI_BASE_URL}/models automatically
#   3. GATEWAY_JUDGE_MODELS — comma-separated static fallback if no /models endpoint
# GATEWAY_MODELS_URL=https://your-llm-gateway-url/admin/models
# GATEWAY_JUDGE_MODELS=my-gpt4,my-claude-haiku,my-gemini-flash

# Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini
# GOOGLE_API_KEY=your-google-api-key-here

# Glean enterprise search
# GLEAN_API_KEY=your-glean-api-key-here


# =============================================================================
# KG WORKER NODES — offload knowledge graph builds to dedicated worker(s)
# =============================================================================
# Run the worker from the worker/ subfolder on a separate server.
# Single worker:
# KG_WORKER_URL=http://kg-worker:3000
#
# Multiple workers (comma-separated, tried in order until one accepts):
# KG_WORKER_URLS=http://kg-worker-1:3000,http://kg-worker-2:3000


# =============================================================================
# OPTIONAL — network access
# =============================================================================
# Set to true if your bot or cited document sources are on a private/internal
# network. When false (default), private IP ranges are blocked to prevent SSRF
# on internet-facing deployments. Only enable on trusted private networks.
# ALLOW_PRIVATE_ENDPOINTS=false

# =============================================================================
# OPTIONAL — storage paths (relative or absolute)
# =============================================================================
# DATABASE_PATH=data/ragas.db
# CHROMADB_PATH=data/chromadb
# BM25_PATH=data/bm25


# =============================================================================
# OPTIONAL — model defaults
# =============================================================================
# DEFAULT_EVAL_MODEL=gpt-4o-mini
# DEFAULT_EVAL_EMBEDDING=text-embedding-3-small
# DEFAULT_EVAL_MAX_TOKENS=16384

# DEFAULT_OPENAI_MODEL=gpt-4o-mini
# DEFAULT_CLAUDE_MODEL=claude-sonnet-4-20250514
# DEFAULT_DEEPSEEK_MODEL=deepseek-chat
# DEFAULT_GEMINI_MODEL=gemini-2.0-flash


# =============================================================================
# OPTIONAL — timeouts, limits, batch sizes
# =============================================================================
# BOT_QUERY_TIMEOUT=120
# TESTGEN_SUBPROCESS_TIMEOUT=7200
# PERSONA_SUBPROCESS_TIMEOUT=3600
# SOURCE_VERIFY_FETCH_TIMEOUT=15

# MAX_UPLOAD_SIZE=52428800
# MAX_BASELINE_CSV_SIZE=10485760
# MAX_BASELINE_ROWS=1000
# MAX_UPLOAD_QA_ROWS=2000

# EMBEDDING_BATCH_SIZE=100
# KG_BATCH_SIZE=50
# PERSONA_MAX_CHARS_PER_BATCH=80000


# =============================================================================
# OPTIONAL — evaluation thresholds
# =============================================================================
# MULTI_LLM_JUDGE_DEFAULT_EVALUATORS=3
# MULTI_LLM_JUDGE_RELIABILITY_THRESHOLD=0.6
# MULTI_LLM_JUDGE_TEMP_MIN=0.3
# MULTI_LLM_JUDGE_TEMP_MAX=0.75
# MULTI_LLM_JUDGE_MODEL_ASSIGNMENTS=gpt-4o-mini,claude-haiku-4-5,gemini-2.0-flash

# SUGGESTION_HIGH_THRESHOLD=0.4
# SUGGESTION_MEDIUM_THRESHOLD=0.7

# CORS (comma-separated allowed origins)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
